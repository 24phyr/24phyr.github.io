cat notes.txt
wc notes.txt
cp notes.txt backup.txt
mv backup.txt archive.txt
rm archive.txt
mkdir private
chmod 700 private 4 2 1 r w x
ls -lh sample.txt //check file attribute perm
grep "String" file.txt
